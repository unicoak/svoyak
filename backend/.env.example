NODE_ENV=development
PORT=3000
PG_CONNECTION_STRING=postgres://postgres:postgres@localhost:5432/svoyak
# Optional Railway fallback if PG_CONNECTION_STRING is omitted:
# DATABASE_URL=postgresql://...
# For managed Postgres with self-signed cert chain (e.g. some cloud setups):
# PG_SSL_REJECT_UNAUTHORIZED=false
REDIS_URL=redis://localhost:6379
ROOM_TTL_SECONDS=86400
BUZZ_RESOLVE_WINDOW_MS=80
DEFAULT_ANSWER_TIME_LIMIT_MS=5000
# Optional: run seed migrations too (for staging/dev only)
# MIGRATE_WITH_SEED=false
